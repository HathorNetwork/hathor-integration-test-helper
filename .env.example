# ============================================================================
# Environment configuration for the Hathor Integration Test Helper.
# ----------------------------------------------------------------------------
# Copy to `.env` (gitignored) before running `bun run start` or `bun run dev`.
# Bun loads `.env` automatically — do not use dotenv. Anything left blank
# falls back to a safe local-dev default; the service emits a structured
# `config.using_default_*` warning at startup so unset values surface in
# CI logs before the first request.
#
# SECURITY: this service is testnet-only by design (`NETWORK = "testnet"`
# is hardcoded in src/config.ts) and is not intended to run against any
# production environment. Even so, never commit a populated `.env`, never
# reuse these values outside throwaway testnet runs, and prefer a vault /
# secret manager for non-trivial deployments.
# ============================================================================

# === Genesis wallet seed (used by the future /fund endpoint) ===
# 24 space-separated BIP-39 words. Leave blank to fall back to
# hathor-wallet-lib's integration genesis seed (WALLET_CONSTANTS.genesis in
# its test-constants), so a dockerized helper is plug-and-play for the Lib
# CI. Override with your own funded testnet wallet for other contexts; treat
# a real value as a secret — anyone holding the seed controls the wallet.
# Not consumed at runtime yet (funding is a later milestone); defaulted now
# for forward-aligned deployment.
GENESIS_SEED_WORDS=""

# === Network endpoints ===
# Hathor full-node (v1a API) and tx-mining service the helper talks to.
# Defaults are convenient for `docker compose up` against the bundled
# privnet stack; override in CI to point at the shared testnet.
HATHOR_NODE_URL="http://localhost:8083/v1a/"
TX_MINING_URL="http://localhost:8035/"

# === Service ===
PORT=3020
SIMPLE_WALLET_CACHE_SIZE=10

# === UTXO pool ===
UTXO_SPLIT_AMOUNT=1000
UTXO_SPLIT_COUNT=100
REFILL_THRESHOLD=10
FUND_TIMEOUT_MS=30000
OBSERVATION_TIMEOUT_MS=30000
MAX_REQUEST_BODY_BYTES=16384

# === Wallet-lib credentials (TESTNET ONLY) ===
# These match the runtime fallback values intentionally so the testnet
# quickstart works without operator setup. They are NOT secrets — they
# protect a wallet that only ever holds testnet funds. Override with
# strong values for any non-throwaway environment; the runtime logs
# `config.using_default_secret` whenever either is left unset.
WALLET_PASSWORD="test-password"
WALLET_PIN_CODE="123456"

# === Test server port fallback policy ===
TEST_PORT_FALLBACK_START=13020
TEST_PORT_FALLBACK_SPAN=1000
